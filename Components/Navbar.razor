<div id="nav" class="flex-vert flex-align-center fill-height">

	<img id="logo" src="/images/logo.jpg">

	<a	hx-trigger="click"
		hx-get="/"
		hx-push-url="/"
		hx-target=".content"
		hx-swap="outerHTML">
		<span id="navbar-header">konym.live</span>
	</a>

    <div id="navlist">
		<a class="navlink" href="/">Home</a>
		<a class="navlink" href="/about">About</a>
		<a class="navlink" href="/zones">Zones</a>
        <a class="navlink" href="/i-made-this">I Made This</a>
        <a class="navlink" href="/shadez-2-full">Shadez 2</a>
    </div>

	<div id="button" class="flex-horiz flex-align-center">
		<a id="button-image" target="_blank" href="https://konym.live" title="To konym.live"><img src="/images/button.png" /></a>
		<img id="clipboard-image" src="/images/clipboard.png" />
	</div>

	<span id="void-fill" />

	<div id="random-vid" class="flex-horiz flex-justify-center">
		<iframe style="width: 90%;" src="@Globals.EmbedLinks.ElementAt((new Random()).Next(Globals.EmbedLinks.Count))" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
	</div>

	<div id="userbadge">
		<UserBadge/>
	</div>

	<style>
		#nav {
			border: 2px solid burlywood;
			background: linear-gradient(190deg,rgba(0, 65, 115, 0.54) 0%, rgba(196, 177, 0, 0.34) 100%);
			
			container-type: inline-size;
			overflow: auto;

			flex: 1;
			gap: 1cqi;

			min-width: 100px;
			max-width: 11vw;
		}

		#logo {
			margin-top: 20px;
			width: 90%;
		}

		#navbar-header {
			font-family: '3dthirteen';
			font-size: 20cqi;
			
			transition: text-shadow 0.3s ease;
		}

		#navbar-header:hover {
			cursor: pointer;
			text-shadow: -1px -1px 0 #FFF, 1px -1px 0 #FFF, -1px 1px 0 #FFF, 1px 1px 0 #FFF;
		}

		#navlist {
			width: 90%;
		}

		.navlink {
			color: burlywood;
			background-color: black;
			border: 1px solid white;
			border-image: linear-gradient(190deg,rgba(0, 65, 115, 1), rgba(196, 177, 0, 1)) 1;

			text-align: center;
			font-size: 7cqi;
			font-weight: bold;
			text-decoration: none;

			padding: 5px;
			margin: 5px 0px;

			display: block;
		}

		#button {
			flex-wrap: wrap;
			gap: 5px;
		}

		#button-image {
			width: 88px;
			height: 31px;
		}

		#clipboard-image {
			height: 31px;
		}

		#clipboard-image:hover {
			cursor: pointer;
		}

		#void-fill {
			flex-grow: 1;
		}

		#random-vid {
			justify-self: flex-end;
		}

		#userbadge {
			align-items: flex-end;
			margin-bottom: 20px;
		}

		.active {
			text-decoration: underline;
		}

		.navlink:hover {
			background: transparent;
			border: 1px solid white;
			/*border-image: linear-gradient(90deg,rgba(0, 65, 115, 0.54), rgba(0, 0, 0, 1), rgba(196, 177, 0, 0.34)) 1;*/
		}
	</style>

	<script>
		document.body.addEventListener("htmx:afterSwap", function() {
			// Get the current page's URL
			const currentUrl = window.location.href;

			// Select all anchor tags within the navbar
			const navLinks = document.querySelectorAll("#navlist a");

			// Loop through the links and add the 'active' class to the matching one
			navLinks.forEach(link =>
			{
				if (link.href === currentUrl)
					link.classList.add('active');
				else
					link.classList.remove('active');

			});

			const clipboard = document.getElementById("clipboard-image");

			clipboard.onclick = async function(event)
			{
				await navigator.clipboard.writeText(`<a target="_blank" href="https://konym.live" title="To konym.live"><img style="width: 88px; height: 31px" src="https://konym.live/images/button.png" /></a>`);
				alert("Copied button html!");
			};
		});
	</script>
</div>