<div class="content flex-vert flex-align-center" align="center">

    <div class="fill-width">
        <span style="font-family: '3dthirteen'; font-size: 5cqi;">Select a Zone</span>
        <hr />
    </div>

    <div id="zones-container" class="flex-horiz flex-justify-center flex-align-center fill-width fill-height">
        <a id="technology-btn" class="zone-btn glowing-btn flex-vert flex-align-center flex-justify-center" href="/zones/technology">Technology</a>
        <a id="life-btn"  class="zone-btn glowing-btn flex-vert flex-align-center flex-justify-center" href="/zones/life">Life</a>
        <a id="cars-and-bikes-btn" class="zone-btn glowing-btn flex-vert flex-align-center flex-justify-center" href="/nothing-yet">Cars and <br />Bikes</a>
    </div>

    <style>
        #zones-container {
            gap: 2px;
            padding: 10px 20px 20px 20px;
        }

        #technology-btn {
            background-image: url(/images/vista_wallpaper.webp);
            background-position-x: 30%;
            background-size: cover;
        }

        #life-btn {
            background-image: url(/images/lake_perris.jpg);
            background-position-x: 60%;
            background-position-y: 80%;
            background-size: cover;
        }

        #cars-and-bikes-btn {
            background-image: url(/images/ktm_pink_tree.jpg);
            background-repeat: no-repeat;
            background-position-x: 60%;
            background-position-y: 80%;
            background-size: cover;
        }

        .zone-btn {
            cursor: pointer;
            padding: 10px;

            width: stretch;
            height: stretch;

            color: burlywood;
            background:black;

            text-decoration: none;

            border: 2px solid transparent;
            border-image: linear-gradient(190deg,rgba(0, 65, 115, 1), rgba(196, 177, 0, 1)) 1;

            font-size: 4cqi;
            font-weight: 100;
            font-family: '3dthirteen';
        }

        .glowing-btn {

            background-color: rgba(0, 0, 0, 0.5);
            background-blend-mode: darken;

            box-shadow: 0 0 15px rgba(0, 65, 115, 0.5);
            width: 100%;

            /* Transition for smooth effect */
            transition: background-color 0.3s ease, box-shadow 0.3s ease, width 0.3s ease;
        }

        .glowing-btn:hover {
            backdrop-filter: blur(500px);
            font-weight: 900;

            z-index: 1;
            background-color: rgba(0, 0, 0, 0);
            box-shadow: 0 0 80px rgba(33, 147, 176, 0.8), 0 0 50px rgba(196, 177, 0, 1);
            width: 200%;
